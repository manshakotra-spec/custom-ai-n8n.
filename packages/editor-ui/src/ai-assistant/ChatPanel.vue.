<template>
  <div>
    <h1>AI Assistant</h1>

    <textarea v-model="message"></textarea>

    <button @click="sendMessage">
      Send
    </button>

    <div>
      {{ response }}
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref } from 'vue';
import { askGemini } from './GeminiService';

const message = ref('');
const response = ref('');

async function sendMessage() {
  response.value = await askGemini(message.value);
}
</script>
